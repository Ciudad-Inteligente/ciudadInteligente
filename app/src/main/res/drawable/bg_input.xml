<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Estado cuando la caja tiene el foco (Activa) -->
    <item android:state_focused="true">
        <shape>
            <solid android:color="#FFFFFF"/>
            <corners android:radius="25dp"/>
            <stroke android:width="2dp" android:color="#B25E15"/> <!-- El naranja de tus botones -->
        </shape>
    </item>

    <!-- Estado por defecto (Inactiva) -->
    <item>
        <shape>
            <solid android:color="#F8F8F8"/> <!-- Un gris muy tenue -->
            <corners android:radius="25dp"/>
            <stroke android:width="1dp" android:color="#D9D9D9"/>
        </shape>
    </item>
</selector>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".LoginUsuario">

    <!-- Fondo -->
    <ImageView
        android:id="@+id/imagenFondo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="fitCenter"
        android:scaleX="1.5"
        android:scaleY="4.5"
        android:src="@drawable/fondologin"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Capa blanca suave -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#55FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scroll -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <!-- Logo -->
            <ImageView
                android:id="@+id/logoApp"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_marginBottom="-20dp"
                android:src="@drawable/logobugareportamas"
                android:contentDescription="@string/app_name"
                android:scaleType="fitCenter" />

            <!-- Frase -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reporta. Mejora. Transforma."
                android:textSize="13sp"
                android:textColor="#6E6E6E"
                android:layout_marginBottom="30dp" />

            <!-- Caja formulario -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_form_login"
                android:padding="24dp"
                android:elevation="8dp">

                <!-- Título -->
                <TextView
                    android:id="@+id/textViewTitulo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:gravity="center"
                    android:text="Iniciar sesión"
                    android:textColor="#61461D"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <!-- Correo -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Correo"
                    android:textSize="14sp"
                    android:textColor="#5E5E5E"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/editTextEmail"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="usuario@correo.com"
                    android:inputType="textEmailAddress"
                    android:autofillHints="emailAddress"
                    android:padding="14dp"
                    android:background="@drawable/bg_input"
                    android:textColor="#2F2F2F"
                    android:textColorHint="#A0A0A0"
                    android:layout_marginBottom="16dp" />

                <!-- Contraseña -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Contraseña"
                    android:textSize="14sp"
                    android:textColor="#5E5E5E"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/editTextPassword"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Contraseña"
                    android:inputType="textPassword"
                    android:autofillHints="password"
                    android:padding="14dp"
                    android:background="@drawable/bg_input"
                    android:textColor="#2F2F2F"
                    android:textColorHint="#A0A0A0"
                    android:layout_marginBottom="14dp" />

                <!-- Checkbox -->
                <CheckBox
                    android:id="@+id/checkboxRecordar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recordar sesión"
                    android:textColor="#5E5E5E"
                    android:buttonTint="#B25E15"
                    android:layout_marginBottom="18dp" />

                <!-- Botón -->
                <Button
                    android:id="@+id/btnEntrar"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Entrar"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="@drawable/bg_button_primary"
                    app:backgroundTint="@null"
                    android:padding="12dp"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="14dp" />


                <!-- Olvidé contraseña -->
                <TextView
                    android:id="@+id/textViewOlvideContrasena"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="¿Olvidaste tu contraseña?"
                    android:textSize="13sp"
                    android:textColor="#B25E15"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="14dp"
                    android:clickable="true"
                    android:focusable="true" />

                <!-- Línea -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginBottom="14dp" />

                <!-- Registro -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¿No tienes cuenta? "
                        android:textColor="#666666"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/textViewRegistrarse"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Regístrate"
                        android:textColor="#B25E15"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

            </LinearLayout>

            <!-- Mensaje -->
            <TextView
                android:id="@+id/textViewMensaje"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#D32F2F"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginTop="10dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

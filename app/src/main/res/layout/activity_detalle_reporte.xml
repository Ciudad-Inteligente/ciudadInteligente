<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".DetalleReporteActivity">

    <!-- Header -->
    <include
        android:id="@+id/header"
        layout="@layout/layout_header"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Espacio para la foto -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="200dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/ivDetalleFoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerInside"
                    android:padding="50dp"
                    android:src="@android:drawable/ic_menu_gallery"
                    android:background="#EEE"
                    app:tint="#CCC" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center|bottom"
                    android:layout_marginBottom="16dp"
                    android:text="Sin imagen adjunta"
                    android:textColor="#888"
                    android:textSize="12sp" />
            </androidx.cardview.widget.CardView>

            <!-- Información principal -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/white_rounded_rect"
                android:padding="16dp"
                android:elevation="2dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvDetalleAsunto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Asunto del reporte"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#222"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvDetalleEstado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PENDIENTE"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:background="@drawable/badge_estado"
                    android:layout_marginBottom="16dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEE"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Información del reporte"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="#444"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Área:"
                        android:textColor="#888"
                        android:textSize="13sp"/>
                    <TextView
                        android:id="@+id/tvDetalleArea"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nombre del área"
                        android:textColor="#444"
                        android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Tipo:"
                        android:textColor="#888"
                        android:textSize="13sp"/>
                    <TextView
                        android:id="@+id/tvDetalleTipo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tipo de reporte"
                        android:textColor="#444"
                        android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Fecha:"
                        android:textColor="#888"
                        android:textSize="13sp"/>
                    <TextView
                        android:id="@+id/tvDetalleFecha"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="01 de enero 2026"
                        android:textColor="#444"
                        android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Ubicación:"
                        android:textColor="#888"
                        android:textSize="13sp"/>
                    <TextView
                        android:id="@+id/tvDetalleDireccion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Carrera 13 # 5-21"
                        android:textColor="#444"
                        android:textSize="13sp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Descripción"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="#444"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvDetalleDescripcion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Aquí va la descripción completa del reporte realizado por el ciudadano."
                    android:textColor="#666"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"/>

            </LinearLayout>

            <!-- Sección de Historial -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/white_rounded_rect"
                android:padding="16dp"
                android:elevation="2dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Historial de seguimiento"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#222"
                    android:layout_marginBottom="16dp"/>

                <!-- Lista de historial -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvHistorial"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

                <TextView
                    android:id="@+id/tvSinHistorial"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Aún no hay actualizaciones en el estado de este reporte."
                    android:textColor="#AAA"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:padding="16dp"
                    android:visibility="gone"/>

            </LinearLayout>

            <!-- Botones de Acción -->
            <Button
                android:id="@+id/btnEditarReporte"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Editar reporte"
                android:textColor="#FFFFFF"
                android:backgroundTint="#B25E15"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                app:cornerRadius="8dp"/>

            <Button
                android:id="@+id/btnEliminarReporte"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Eliminar reporte"
                android:textColor="#D32F2F"
                android:backgroundTint="#FFEBEE"
                android:textStyle="bold"
                android:layout_marginBottom="32dp"
                app:cornerRadius="8dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- Navbar -->
    <include
        android:id="@+id/bottomNavigationView"
        layout="@layout/layout_navbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

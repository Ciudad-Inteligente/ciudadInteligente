<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".AdjuntarFotoReporteActivity">

    <!-- Header Incluido -->
    <include
        android:id="@+id/header"
        layout="@layout/layout_header"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="3. Foto (Opcional)"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#222"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Adjuntar una imagen ayuda a las autoridades a entender mejor el problema."
                android:textSize="14sp"
                android:textColor="#666"
                android:layout_marginBottom="24dp"/>

            <!-- Corregido: usando icono del sistema para evitar el error de archivo faltante -->
            <ImageView
                android:id="@+id/imgFotoPrevia"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:background="#E0E0E0"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_menu_camera"
                android:layout_marginBottom="12dp"
                android:padding="40dp"
                app:tint="#888"/>

            <TextView
                android:id="@+id/tvEstadoFoto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No se ha seleccionado ninguna foto"
                android:textSize="12sp"
                android:textColor="#888"
                android:layout_marginBottom="24dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="32dp">

                <Button
                    android:id="@+id/btnTomarFoto"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Cámara"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_button_secondary"
                    app:backgroundTint="@null"
                    android:textColor="#555"/>

                <Button
                    android:id="@+id/btnSeleccionarFoto"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Galería"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_button_secondary"
                    app:backgroundTint="@null"
                    android:textColor="#555"/>

            </LinearLayout>

            <Button
                android:id="@+id/btnEnviarReporte"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Enviar reporte"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_button_primary"
                app:backgroundTint="@null"/>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>

    <!-- Navbar Incluido -->
    <include
        android:id="@+id/bottomNavigationView"
        layout="@layout/layout_navbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

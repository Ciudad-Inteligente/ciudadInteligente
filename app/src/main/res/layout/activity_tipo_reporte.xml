<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".TipoReporteActivity">

    <!-- Header Incluido -->
    <include
        android:id="@+id/header"
        layout="@layout/layout_header"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Contenido scrollable -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Nombre del área seleccionada (viene de la pantalla anterior) -->
            <TextView
                android:id="@+id/tvNombreArea"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Área de reporte"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#222"
                android:layout_marginBottom="6dp"/>

            <!-- Descripción del área -->
            <TextView
                android:id="@+id/tvDescripcionArea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="#666"
                android:layout_marginBottom="20dp"/>

            <!-- Subtítulo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selecciona el tipo de reporte"
                android:textSize="15sp"
                android:textColor="#444"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- Indicador de carga -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="visible"/>

            <!-- Mensaje vacío -->
            <TextView
                android:id="@+id/tvSinTipos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No hay tipos de reporte para esta área aún."
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                android:gravity="center"
                android:padding="20dp"
                android:visibility="gone"/>

            <!-- RecyclerView para tipos -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerTipos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </ScrollView>

    <!-- Navbar Incluido -->
    <include
        android:id="@+id/bottomNavigationView"
        layout="@layout/layout_navbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

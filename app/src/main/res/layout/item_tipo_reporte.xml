<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="8dp">

    <androidx.cardview.widget.CardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/cardCirculo"
        android:layout_width="90dp"
        android:layout_height="90dp"
        app:cardCornerRadius="45dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFE0B2">

        <!--
            ImageView en lugar de TextView —
            mostrará el drawable local por nombre
        -->
        <ImageView
            android:id="@+id/imgIcono"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:contentDescription="Ícono del tipo de reporte"
            android:src="@drawable/ic_default"/>

    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvNombreTipo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tipo de reporte"
        android:textSize="12sp"
        android:textColor="#333"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:maxLines="2"
        android:ellipsize="end"/>

</LinearLayout>
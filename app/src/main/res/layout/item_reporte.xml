<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Franja de color a la izquierda (decorativa) -->
        <View
            android:layout_width="4dp"
            android:layout_height="48dp"
            android:background="#E07A1B"
            android:layout_marginEnd="12dp"/>

        <!-- Textos: asunto, tipo y fecha -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvItemAsunto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Asunto del reporte"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#222"/>

            <TextView
                android:id="@+id/tvItemTipo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tipo"
                android:textSize="12sp"
                android:textColor="#888"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvItemFecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01 ene 2026"
                android:textSize="11sp"
                android:textColor="#AAAAAA"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- Badge de estado a la derecha -->
        <TextView
            android:id="@+id/tvItemEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pendiente"
            android:textSize="11sp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp"
            android:background="@drawable/badge_estado"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
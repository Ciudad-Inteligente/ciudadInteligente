<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/imgReporte"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_foreground"
            android:background="@drawable/rounded_image_bg"
            android:contentDescription="Imagen del reporte" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:id="@+id/tituloReporte"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Título del reporte"
                android:textStyle="bold"
                android:textColor="#222"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tiempoReporte"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hace 2 días"
                android:textColor="#666"
                android:textSize="13sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/estadoReporte"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="En proceso"
            android:background="@drawable/estado_en_proceso_bg"
            android:textColor="#228B22"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:textSize="13sp"
            android:layout_marginStart="8dp"
            android:layout_gravity="center_vertical" />
    </LinearLayout>

</androidx.cardview.widget.CardView>


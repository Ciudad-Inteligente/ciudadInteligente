<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".CrearReporteActivity">

    <!-- Header igual a todas las pantallas -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#E07A1B"
        android:padding="12dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/logobugareporta"
            android:contentDescription="@string/logo_description"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_title"
                android:textColor="#FFF"
                android:textStyle="bold"
                android:textSize="18sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_slogan"
                android:textColor="#FFF"
                android:textSize="12sp"/>

        </LinearLayout>

        <ImageView
            android:id="@+id/btnPerfil"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_launcher_foreground"
            android:background="@drawable/circle_bg"
            android:contentDescription="@string/profile_description"
            android:padding="2dp"/>

    </LinearLayout>

    <!-- Contenido scrollable -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Indicador de paso: "1. Datos" -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1. Datos"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#222"
                android:layout_marginBottom="4dp"/>

            <!-- Chip que muestra área y tipo seleccionados -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/tvChipArea"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Área"
                    android:textSize="12sp"
                    android:textColor="#E07A1B"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:background="@drawable/chip_naranja"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tvChipTipo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tipo"
                    android:textSize="12sp"
                    android:textColor="#555"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:background="@drawable/chip_gris"/>

            </LinearLayout>

            <!-- Campo: Asunto -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Asunto *"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#333"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etAsunto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ej: Semáforo no está funcionando"
                android:inputType="text"
                android:maxLines="1"
                android:padding="12dp"
                android:background="@drawable/input_bg"
                android:layout_marginBottom="16dp"/>

            <!-- Campo: Descripción -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Descripción *"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#333"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etDescripcion"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:hint="Describe el problema con el mayor detalle posible..."
                android:inputType="textMultiLine"
                android:gravity="top"
                android:padding="12dp"
                android:background="@drawable/input_bg"
                android:layout_marginBottom="8dp"/>

            <!-- Contador de caracteres -->
            <TextView
                android:id="@+id/tvContador"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 / 300"
                android:textSize="11sp"
                android:textColor="#AAAAAA"
                android:layout_gravity="end"
                android:layout_marginBottom="24dp"/>

            <!-- Mensaje de error -->
            <TextView
                android:id="@+id/tvMensaje"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#D32F2F"
                android:textSize="13sp"
                android:layout_marginBottom="8dp"
                android:visibility="gone"/>

            <!-- Botón siguiente -->
            <Button
                android:id="@+id/btnSiguiente"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Siguiente"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#E07A1B"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- Navbar -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#FFF"
        app:menu="@menu/bottom_nav_menu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
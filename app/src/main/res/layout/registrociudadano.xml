<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".RegistroCiudadano">

    <!-- Fondo -->
    <ImageView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="fitCenter"
        android:scaleX="1.5"
        android:scaleY="4.5"
        android:src="@drawable/fondologin"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Capa blanca -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#55FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scroll -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <!-- Logo -->
            <ImageView
                android:id="@+id/logoImageView"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_marginBottom="-20dp"
                android:src="@drawable/logobugareportamas"
                android:contentDescription="@string/app_name"
                android:scaleType="fitCenter" />

            <!-- Frase -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reporta. Mejora. Transforma."
                android:textSize="12sp"
                android:textColor="#6E6E6E"
                android:layout_marginBottom="20dp" />

            <!-- Caja formulario -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_form_login"
                android:padding="24dp"
                android:elevation="8dp">

                <!-- Título -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Crear cuenta"
                    android:textSize="22sp"
                    android:textColor="#61461D"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="20dp" />

                <!-- Identificación -->
                <EditText
                    android:id="@+id/editTextIdentificacion"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Identificación"
                    android:padding="14dp"
                    android:background="@drawable/bg_input"
                    android:textColor="#2F2F2F"
                    android:textColorHint="#A0A0A0"
                    android:layout_marginBottom="12dp" />

                <!-- Nombre -->
                <EditText
                    android:id="@+id/editTextNombre"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Nombre"
                    android:padding="14dp"
                    android:background="@drawable/bg_input"
                    android:textColor="#2F2F2F"
                    android:textColorHint="#A0A0A0"
                    android:layout_marginBottom="12dp" />

                <!-- Correo -->
                <EditText
                    android:id="@+id/editTextCorreo"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Correo electrónico"
                    android:inputType="textEmailAddress"
                    android:padding="14dp"
                    android:background="@drawable/bg_input"
                    android:textColor="#2F2F2F"
                    android:textColorHint="#A0A0A0"
                    android:layout_marginBottom="12dp" />

                <!-- Contraseña -->
                <EditText
                    android:id="@+id/editTextPassword"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Contraseña"
                    android:inputType="textPassword"
                    android:padding="14dp"
                    android:background="@drawable/bg_input"
                    android:textColor="#2F2F2F"
                    android:textColorHint="#A0A0A0"
                    android:layout_marginBottom="12dp" />

                <!-- Confirmar -->
                <EditText
                    android:id="@+id/editTextConfirmarPassword"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Confirmar contraseña"
                    android:inputType="textPassword"
                    android:padding="14dp"
                    android:background="@drawable/bg_input"
                    android:textColor="#2F2F2F"
                    android:textColorHint="#A0A0A0"
                    android:layout_marginBottom="16dp" />

                <!-- Botón -->
                <Button
                    android:id="@+id/btnRegistrar"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Registrarse"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="@drawable/bg_button_primary"
                    app:backgroundTint="@null"
                    android:padding="12dp"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="12dp" />

                <!-- Mensaje -->
                <TextView
                    android:id="@+id/textViewMensaje"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textAlignment="center"
                    android:textColor="@android:color/holo_red_dark"
                    android:textSize="13sp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

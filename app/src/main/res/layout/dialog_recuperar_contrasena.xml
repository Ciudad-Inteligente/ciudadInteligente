<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_background"
    android:padding="24dp">

    <!-- Título del diálogo -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/titulo_recuperar_contrasena"
        android:textSize="22sp"
        android:textColor="#61461D"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Mensaje informativo -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/mensaje_recuperacion_informativo"
        android:textSize="14sp"
        android:textColor="#6E6E6E"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- Campo de correo electrónico -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_email"
        android:textSize="14sp"
        android:textColor="#5E5E5E"
        android:layout_marginBottom="6dp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/editTextEmailRecuperar"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="@string/hint_email"
        android:inputType="textEmailAddress"
        android:padding="14dp"
        android:background="@drawable/bg_input"
        android:textColor="#2F2F2F"
        android:textColorHint="#A0A0A0"
        android:layout_marginBottom="16dp" />

    <!-- Mensaje de error/info -->
    <TextView
        android:id="@+id/textViewMensajeRecuperacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#D32F2F"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginBottom="20dp"
        android:visibility="gone" />

    <!-- Contenedor de botones -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Botón Cancelar -->
        <Button
            android:id="@+id/btnCancelarRecuperacion"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/boton_cancelar"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/bg_button_secondary"
            app:backgroundTint="@null"
            android:padding="12dp" />

        <!-- Botón Recuperar Contraseña -->
        <Button
            android:id="@+id/btnRecuperarContrasena"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1.3"
            android:layout_marginStart="8dp"
            android:text="Recuperar"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/bg_button_primary"
            app:backgroundTint="@null"
            android:padding="12dp" />

    </LinearLayout>

</LinearLayout>
